# Image Restore — environment configuration
#
# No keys are required to run the app. Without any of the keys below, the
# app uses the built-in Standard Engine: real algorithmic image processing
# (denoise, sharpen, color normalize, high-quality upscale) via sharp/libvips.
# It is clearly labeled in the UI as non-AI.
#
# Setting one of these keys switches the factory in
# lib/image-processing/service.ts to the matching provider class. Those
# provider classes (lib/image-processing/providers/*) are currently stubs —
# implement the API call in the matching file to go live.

# Replicate (e.g. GFPGAN / Real-ESRGAN style restoration models)
REPLICATE_API_TOKEN=

# Stability AI (image-to-image upscaling / enhancement)
STABILITY_API_KEY=

# OpenAI (reserved for future image tooling)
OPENAI_API_KEY=
